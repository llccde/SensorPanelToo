<Window x:Class="SensorPanelToo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SensorPanelToo.Controls"
        Title="SensorPanelToo 控制台" Height="660" Width="960"
        Background="#F0F0F0" WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style x:Key="SideTabBtn" TargetType="Button">
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#D0D0D0"/>
                    <Setter Property="Foreground" Value="#333"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8E8E8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left Sidebar -->
        <Border Grid.Column="0" Background="#E5E5E5">
            <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                <Button x:Name="TabTheme" Content="主题" Style="{StaticResource SideTabBtn}"
                        Click="TabTheme_Click"/>
                <Button x:Name="TabDebug" Content="调试" Style="{StaticResource SideTabBtn}"
                        Click="TabDebug_Click" Margin="0,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <Grid Margin="12">

                <!-- === Theme Tab === -->
                <Grid x:Name="PanelTheme" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <controls:ThemeSelector x:Name="ThemeSelector" Grid.Row="0"
                                            ThemeSelected="ThemeSelector_ThemeSelected"
                                            ThemeDoubleClicked="ThemeSelector_ThemeDoubleClicked"/>

                    <Border Grid.Row="1" Background="White" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="8" Margin="0,8,0,0">
                        <WrapPanel>
                            <Button x:Name="NewThemeBtn" Content="新建" Width="60" Height="28" FontSize="12" FontWeight="SemiBold"
                                    Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="NewThemeBtn_Click" Margin="0,0,8,0"/>
                            <Button x:Name="EditThemeBtn" Content="编辑" Width="60" Height="28" FontSize="12" FontWeight="SemiBold"
                                    Background="#0066CC" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="EditThemeBtn_Click" Margin="0,0,12,0"/>

                            <Rectangle Width="1" Fill="#DDD" Margin="0,3,12,3"/>

                            <CheckBox x:Name="FullscreenCheck" Content="全屏" IsChecked="True"
                                      FontSize="12" Foreground="#333" VerticalAlignment="Center" Margin="0,0,10,0"
                                      Checked="FullscreenCheck_Changed" Unchecked="FullscreenCheck_Changed"/>

                            <ComboBox x:Name="MonitorCombo" Height="24" FontSize="11" Width="170" VerticalAlignment="Center"
                                      SelectionChanged="MonitorCombo_SelectionChanged" Margin="0,0,10,0"
                                      IsEnabled="{Binding ElementName=FullscreenCheck, Path=IsChecked}"/>

                            <Button x:Name="StartServiceBtn" Content="硬件服务" Width="70" Height="24" FontSize="11"
                                    Click="StartServiceBtn_Click" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ServiceStatusLabel" Foreground="#888" FontSize="11" VerticalAlignment="Center" Margin="0,0,10,0" Width="80"/>

                            <Button x:Name="RenderThemeBtn" Content="渲染" Width="64" Height="28" FontSize="13" FontWeight="Bold"
                                    Background="#28A745" Foreground="White" BorderThickness="0" Cursor="Hand"
                                    Click="RenderThemeBtn_Click"/>
                        </WrapPanel>
                    </Border>
                </Grid>

                <!-- === Debug Tab === -->
                <Grid x:Name="PanelDebug" Visibility="Collapsed">
                    <controls:ComponentDebugPanel x:Name="DebugPanel"/>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
