<UserControl x:Class="SensorPanelToo.Controls.ComponentDebugPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:SensorPanelToo.Controls"
             Background="#F0F0F0">
    <UserControl.Resources>
        <Style TargetType="Label" x:Key="PropLabel">
            <Setter Property="Foreground" Value="#333"/><Setter Property="FontSize" Value="11"/><Setter Property="Margin" Value="0,4,0,1"/>
        </Style>
        <Style TargetType="TextBox" x:Key="PropTextBox">
            <Setter Property="Background" Value="#FAFAFA"/><Setter Property="Foreground" Value="#222"/><Setter Property="BorderBrush" Value="#CCC"/><Setter Property="Height" Value="22"/><Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="PropCheck">
            <Setter Property="Foreground" Value="#222"/><Setter Property="FontSize" Value="11"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="6,5">
            <WrapPanel>
                <TextBlock Text="组件:" Foreground="#555" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                <ComboBox x:Name="ComponentTypeCombo" Width="120" Height="24" SelectionChanged="ComponentTypeCombo_SelectionChanged" FontSize="11">
                    <ComboBoxItem Tag="CircularGauge" IsSelected="True">环形仪表</ComboBoxItem>
                    <ComboBoxItem Tag="ProgressBar">进度条</ComboBoxItem>
                    <ComboBoxItem Tag="DigitalDisplay">数字显示</ComboBoxItem>
                    <ComboBoxItem Tag="GridChart">折线图</ComboBoxItem>
                </ComboBox>
                <TextBlock Text="数值:" Foreground="#555" VerticalAlignment="Center" FontSize="12" Margin="12,0,4,0"/>
                <Slider x:Name="ValueSlider" Minimum="0" Maximum="100" Value="45" Width="100" VerticalAlignment="Center" ValueChanged="ValueSlider_ValueChanged"/>
                <TextBlock x:Name="ValueLabel" Text="45%" Foreground="#0066CC" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0" Width="36"/>
                <Rectangle Width="1" Fill="#DDD" Margin="10,2,10,2"/>
                <Button x:Name="SetupHwBtn" Content="硬件" Width="44" Height="22" FontSize="10" Click="SetupHwBtn_Click"/>
                <Button x:Name="SelectSensorBtn" Content="传感器" Width="50" Height="22" FontSize="10" Click="SelectSensorBtn_Click" Margin="2,0,0,0"/>
                <TextBlock x:Name="RealSensorLabel" Text="" Foreground="#0066CC" FontSize="11" VerticalAlignment="Center" Margin="6,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                <Button x:Name="ClearBindBtn" Content="X" Width="20" Height="20" Click="ClearBindBtn_Click" FontSize="9" ToolTip="清除绑定"/>
            </WrapPanel>
        </Border>

        <Border x:Name="TreePopup" Grid.Row="1" Panel.ZIndex="10" VerticalAlignment="Top" HorizontalAlignment="Right" Width="280" Height="340" Margin="0,8,240,0" Background="White" BorderBrush="#CCC" BorderThickness="1" Visibility="Collapsed" CornerRadius="4">
            <Grid Margin="4">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,2">
                    <TextBlock Text="选择传感器" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Foreground="#333"/>
                    <Button Content="X" Width="18" Height="18" FontSize="9" HorizontalAlignment="Right" Margin="140,0,0,0" Click="CloseTreePopup_Click"/>
                </StackPanel>
                <controls:SensorTreeSelector x:Name="SensorTreeSelector" Grid.Row="1" SelectionChanged="SensorTreeSelector_SelectionChanged"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="3"/><ColumnDefinition Width="250"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F8F8F8" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#DDD" BorderThickness="1" Width="480" Height="480">
                <Canvas x:Name="RenderCanvas" Width="480" Height="480" ClipToBounds="True" Background="White">
                    <controls:ProgressBarControl x:Name="ProgressBarCtrl" Visibility="Collapsed"/>
                    <controls:CircularGaugeControl x:Name="CircularGaugeCtrl"/>
                    <controls:DigitalDisplayControl x:Name="DigitalDisplayCtrl" Visibility="Collapsed"/>
                    <controls:GridChartControl x:Name="GridChartCtrl" Visibility="Collapsed"/>
                </Canvas>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="#DDD" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="0,6,4,6">
                <StackPanel x:Name="PropertyPanel" Margin="2,0,0,0">
                    <TextBlock Text="尺寸" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,6,0,2"/>
                    <Label Content="缩放" Style="{StaticResource PropLabel}"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                        <Slider x:Name="ScaleSlider" Minimum="0.2" Maximum="3.0" Value="1.0" ValueChanged="SliderVC"/>
                        <TextBox x:Name="ScaleBox" Grid.Column="1" Text="1.0" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                    </Grid>

                    <TextBlock Text="外观" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,10,0,2"/>
                    <Label Content="前景色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropForeground" Text="#FF6644" Style="{StaticResource PropTextBox}"/>
                    <Label Content="背景色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropBackground" Text="#00000000" Style="{StaticResource PropTextBox}"/>
                    <CheckBox x:Name="PropTransparent" Content="透明背景" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,4,0,1" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                    <Label Content="字体" Style="{StaticResource PropLabel}"/>
                    <ComboBox x:Name="PropFontFamily" Height="22" FontSize="11" SelectionChanged="PropFontFamily_SelectionChanged">
                        <ComboBoxItem FontFamily="Arial">Arial</ComboBoxItem>
                        <ComboBoxItem FontFamily="Calibri">Calibri</ComboBoxItem>
                        <ComboBoxItem FontFamily="Consolas" IsSelected="True">Consolas</ComboBoxItem>
                        <ComboBoxItem FontFamily="Segoe UI">Segoe UI</ComboBoxItem>
                        <ComboBoxItem FontFamily="Tahoma">Tahoma</ComboBoxItem>
                        <ComboBoxItem FontFamily="Verdana">Verdana</ComboBoxItem>
                    </ComboBox>
                    <Label Content="字号" Style="{StaticResource PropLabel}"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                        <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72" Value="14" ValueChanged="SliderVC"/>
                        <TextBox x:Name="FontSizeBox" Grid.Column="1" Text="14" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                    </Grid>

                    <StackPanel x:Name="PanelProgress" Visibility="Collapsed">
                        <TextBlock Text="进度条" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,10,0,2"/>
                        <CheckBox x:Name="PropShowValueText" Content="显示数值" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,4,0,1" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="文字颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropProgressTextColor" Text="#FFFFFF" Style="{StaticResource PropTextBox}"/>
                        <Label Content="边框厚度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="BorderThicknessSlider" Minimum="0" Maximum="10" Value="0" ValueChanged="SliderVC"/>
                            <TextBox x:Name="BorderThicknessBox" Grid.Column="1" Text="0" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="边框颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropBorderColor" Text="#CCCCCC" Style="{StaticResource PropTextBox}"/>
                        <Label Content="圆角" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="RoundnessSlider" Minimum="0" Maximum="40" Value="0" ValueChanged="SliderVC"/>
                            <TextBox x:Name="RoundnessBox" Grid.Column="1" Text="0" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="PanelGauge">
                        <TextBlock Text="环形仪表" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,10,0,2"/>
                        <Label Content="扇形角度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="SweepAngleSlider" Minimum="60" Maximum="360" Value="270" ValueChanged="SliderVC"/>
                            <TextBox x:Name="SweepAngleBox" Grid.Column="1" Text="270" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="起始角度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="StartAngleSlider" Minimum="-180" Maximum="180" Value="-135" ValueChanged="SliderVC"/>
                            <TextBox x:Name="StartAngleBox" Grid.Column="1" Text="-135" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="环厚度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="RingThicknessSlider" Minimum="2" Maximum="60" Value="14" ValueChanged="SliderVC"/>
                            <TextBox x:Name="RingThicknessBox" Grid.Column="1" Text="14" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <CheckBox x:Name="PropNeedleEnabled" Content="显示指针" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,4,0,1" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="指针颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropNeedleColor" Text="#FF0000" Style="{StaticResource PropTextBox}"/>
                        <Label Content="指针宽度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="NeedleWidthSlider" Minimum="0.5" Maximum="10" Value="2.5" ValueChanged="SliderVC"/>
                            <TextBox x:Name="NeedleWidthBox" Grid.Column="1" Text="2.5" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <CheckBox x:Name="PropShowCenterValue" Content="显示中心数值" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,4,0,1" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="文字颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropGaugeTextColor" Text="#FFFFFF" Style="{StaticResource PropTextBox}"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelDisplay" Visibility="Collapsed">
                        <TextBlock Text="数字显示" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,10,0,2"/>
                        <CheckBox x:Name="PropShowSuffix" Content="显示单位" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,4,0,1" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="小数位数" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="DecimalPlacesSlider" Minimum="0" Maximum="6" Value="1" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBox x:Name="DecimalPlacesBox" Grid.Column="1" Text="1" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="描边颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropStrokeColor" Text="#CCCCCC" Style="{StaticResource PropTextBox}"/>
                        <Label Content="描边厚度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="StrokeThicknessSlider" Minimum="0" Maximum="8" Value="1" ValueChanged="SliderVC"/>
                            <TextBox x:Name="StrokeThicknessBox" Grid.Column="1" Text="1" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="PanelChart" Visibility="Collapsed">
                        <TextBlock Text="折线图" Foreground="#999" FontSize="10" FontWeight="Bold" Margin="0,10,0,2"/>
                        <Label Content="时长(秒)" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="DurationSlider" Minimum="10" Maximum="300" Value="60" ValueChanged="SliderVC"/>
                            <TextBox x:Name="DurationBox" Grid.Column="1" Text="60" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="横网格" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="GridXSlider" Minimum="1" Maximum="20" Value="5" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBox x:Name="GridXBox" Grid.Column="1" Text="5" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="纵网格" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="GridYSlider" Minimum="1" Maximum="20" Value="4" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBox x:Name="GridYBox" Grid.Column="1" Text="4" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="线宽" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="LineWidthSlider" Minimum="0.5" Maximum="8" Value="2" ValueChanged="SliderVC"/>
                            <TextBox x:Name="LineWidthBox" Grid.Column="1" Text="2" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="线颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropLineColor" Text="#0066CC" Style="{StaticResource PropTextBox}"/>
                        <Label Content="网格颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropGridLineColor" Text="#E0E0E0" Style="{StaticResource PropTextBox}"/>
                        <Label Content="平滑度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="SmoothFactorSlider" Minimum="0" Maximum="1" Value="0.3" ValueChanged="SliderVC"/>
                            <TextBox x:Name="SmoothFactorBox" Grid.Column="1" Text="0.3" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                        <CheckBox x:Name="PropShowFill" Content="显示填充" IsChecked="False" Style="{StaticResource PropCheck}" Margin="0,4,0,1" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="填充透明度" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions>
                            <Slider x:Name="FillOpacitySlider" Minimum="0" Maximum="1" Value="0.2" ValueChanged="SliderVC"/>
                            <TextBox x:Name="FillOpacityBox" Grid.Column="1" Text="0.2" Width="36" Height="20" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="10" KeyDown="BoxKD"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
