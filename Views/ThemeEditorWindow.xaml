<Window x:Class="SensorPanelToo.Views.ThemeEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SensorPanelToo.Controls"
        Title="Theme Editor" Height="880" Width="1500"
        Background="#F0F0F0" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Label" x:Key="PropLabel">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style TargetType="TextBox" x:Key="PropTextBox">
            <Setter Property="Background" Value="#FAFAFA"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="PropCheck">
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ========== Top Toolbar ========== -->
        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10,6">
            <WrapPanel>
                <Button x:Name="BgImageBtn" Content="背景图" Width="62" Height="26" FontSize="11" Click="BgImageBtn_Click" ToolTip="设置背景图片"/>
                <Rectangle Width="1" Fill="#DDD" Margin="6,2,6,2"/>
                <Button x:Name="AddGaugeBtn" Content="+ Gauge" Width="70" Height="26" FontSize="11" Click="AddGaugeBtn_Click" ToolTip="Add Circular Gauge"/>
                <Button x:Name="AddProgressBtn" Content="+ Progress" Width="72" Height="26" FontSize="11" Click="AddProgressBtn_Click" Margin="2,0,0,0" ToolTip="Add Progress Bar"/>
                <Button x:Name="AddDisplayBtn" Content="+ Display" Width="70" Height="26" FontSize="11" Click="AddDisplayBtn_Click" Margin="2,0,0,0" ToolTip="Add Digital Display"/>
                <Button x:Name="AddChartBtn" Content="+ Chart" Width="64" Height="26" FontSize="11" Click="AddChartBtn_Click" Margin="2,0,0,0" ToolTip="Add Grid Chart"/>
                <Button x:Name="AddLabelBtn" Content="+ Label" Width="64" Height="26" FontSize="11" Click="AddLabelBtn_Click" Margin="2,0,0,0" ToolTip="Add Sensor Label"/>
                <Rectangle Width="1" Fill="#DDD" Margin="10,2,10,2"/>
                <Button x:Name="DeleteBtn" Content="Delete" Width="56" Height="26" FontSize="11" Click="DeleteBtn_Click" ToolTip="Delete selected component"/>
                <Rectangle Width="1" Fill="#DDD" Margin="10,2,10,2"/>
                <TextBlock Text="Sim:" Foreground="#555" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                <Slider x:Name="ValueSlider" Minimum="0" Maximum="100" Value="50" Width="120" VerticalAlignment="Center" ValueChanged="ValueSlider_ValueChanged"/>
                <TextBlock x:Name="ValueLabel" Text="50%" Foreground="#0066CC" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="6,0,0,0" Width="40"/>
                <Rectangle Width="1" Fill="#DDD" Margin="10,2,10,2"/>
                <TextBlock Text="Zoom:" Foreground="#555" VerticalAlignment="Center" FontSize="12" Margin="0,0,4,0"/>
                <Slider x:Name="CanvasZoomSlider" Minimum="0.25" Maximum="3.0" Value="1.0" Width="100" VerticalAlignment="Center" ValueChanged="CanvasZoom_ValueChanged"/>
                <TextBlock x:Name="CanvasZoomLabel" Text="100%" Foreground="#0066CC" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="4,0,0,0" Width="38"/>
                <Rectangle Width="1" Fill="#DDD" Margin="10,2,10,2"/>
                <TextBlock Text="W:" Foreground="#555" VerticalAlignment="Center" FontSize="12" Margin="0,0,2,0"/>
                <TextBox x:Name="CanvasWidthBox" Text="1280" Width="44" Height="24" VerticalAlignment="Center" FontSize="12" KeyDown="CanvasSize_KeyDown"/>
                <TextBlock Text="H:" Foreground="#555" VerticalAlignment="Center" FontSize="12" Margin="6,0,2,0"/>
                <TextBox x:Name="CanvasHeightBox" Text="720" Width="44" Height="24" VerticalAlignment="Center" FontSize="12" KeyDown="CanvasSize_KeyDown"/>
                <Button x:Name="CanvasSizeBtn" Content="Apply" Width="44" Height="24" FontSize="10" Click="CanvasSizeBtn_Click" Margin="4,0,0,0"/>
                <Rectangle Width="1" Fill="#DDD" Margin="10,2,10,2"/>
                <Button x:Name="SetupHwBtn" Content="Setup Hardware" Width="100" Height="26" FontSize="11" Click="SetupHwBtn_Click"/>
                <Rectangle Width="1" Fill="#DDD" Margin="10,2,10,2"/>
                <TextBlock x:Name="ThemeNameLabel" Text="未保存" Foreground="#888" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" MaxWidth="120" TextTrimming="CharacterEllipsis"/>
                <Rectangle Width="1" Fill="#DDD" Margin="0,2,6,2"/>
                <Button x:Name="SaveThemeBtn" Content="保存" Width="56" Height="28" FontSize="11" FontWeight="Bold" Click="SaveThemeBtn_Click" Background="#0066CC" Foreground="White" BorderThickness="0"/>
                <Button x:Name="SaveAsBtn" Content="另存为" Width="56" Height="28" FontSize="11" Click="SaveAsBtn_Click" Margin="2,0,0,0"/>
                <Button x:Name="LoadThemeBtn" Content="加载" Width="56" Height="28" FontSize="11" Click="LoadThemeBtn_Click" Margin="2,0,0,0"/>
            </WrapPanel>
        </Border>

        <!-- ========== Main Area: Left | Center | Right ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3"/>
                <ColumnDefinition Width="330"/>
            </Grid.ColumnDefinitions>

            <!-- ===== Left Panel ===== -->
            <Grid Grid.Column="0" Margin="4,4,0,4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="280"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Components" Foreground="#555" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                <ListBox x:Name="ComponentListBox" Grid.Row="1"
                         SelectionChanged="ComponentList_SelectionChanged"
                         Background="White" BorderBrush="#CCC" BorderThickness="1">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="6,4"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ComponentType}" Margin="0" VerticalAlignment="Center" Foreground="#222"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="2" Text="Sensor Tree" Foreground="#555" FontWeight="Bold" FontSize="13" Margin="0,10,0,4"/>
                <Button x:Name="BindSensorBtn" Grid.Row="3" Content="Bind to Selected" Height="24" FontSize="11" Click="BindSensorBtn_Click" Margin="0,0,0,2"/>
                <GridSplitter Grid.Row="4" Height="3" Background="#DDD" HorizontalAlignment="Stretch"/>
                <controls:SensorTreeSelector x:Name="SensorTree" Grid.Row="5" Margin="0,0,0,0"/>
            </Grid>

            <GridSplitter Grid.Column="1" Width="3" Background="#DDD" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- ===== Center Canvas ===== -->
            <ScrollViewer x:Name="CanvasScroller" Grid.Column="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#D0D0D0">
                <Canvas x:Name="RenderCanvas" Width="1280" Height="720" Background="#FFFFFF"
                        ClipToBounds="True" Focusable="True"
                        PreviewMouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                        PreviewMouseMove="Canvas_MouseMove"
                        PreviewMouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                        PreviewMouseWheel="Canvas_MouseWheel"
                        KeyDown="Canvas_KeyDown">
                    <Image x:Name="BgImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"
                           Panel.ZIndex="-100" MouseLeftButtonDown="BgImage_MouseLeftButtonDown"/>
                </Canvas>
            </ScrollViewer>

            <GridSplitter Grid.Column="3" Width="3" Background="#DDD" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- ===== Right Property Panel ===== -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto" Margin="0,6,4,6">
                <StackPanel x:Name="PropertyPanelRoot" Margin="4,0,0,0">
                    <!-- Placeholder when no selection -->
                    <TextBlock x:Name="NoSelectionLabel" Text="点击组件或背景进行编辑" Foreground="#999"
                               FontSize="13" Margin="0,20,0,0" TextWrapping="Wrap" HorizontalAlignment="Center"/>

                    <!-- Selected component info -->
                    <StackPanel x:Name="PanelSelection" Visibility="Collapsed">
                        <TextBlock Text="Selected" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,0,0,2"/>
                        <TextBlock x:Name="SelectedInfo" Foreground="#0066CC" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,2"/>
                        <TextBlock x:Name="BoundSensorLabel" Foreground="#888" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <!-- ===== Size ===== -->
                        <TextBlock Text="尺寸" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,8,0,4"/>
                        <Label Content="缩放" Style="{StaticResource PropLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="ScaleSlider" Minimum="0.2" Maximum="3.0" Value="1.0" ValueChanged="SliderVC"/>
                            <TextBox x:Name="ScaleBox" Grid.Column="1" Text="1.0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="X 位置" Style="{StaticResource PropLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="PosXSlider" Minimum="0" Maximum="1280" Value="0" ValueChanged="SliderVC"/>
                            <TextBox x:Name="PosXBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="Y 位置" Style="{StaticResource PropLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="PosYSlider" Minimum="0" Maximum="720" Value="0" ValueChanged="SliderVC"/>
                            <TextBox x:Name="PosYBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>

                        <!-- ===== Appearance ===== -->
                        <TextBlock Text="外观" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4"/>
                        <Label Content="前景色" Style="{StaticResource PropLabel}"/>
                        <TextBox x:Name="PropForeground" Text="#00FF88" Style="{StaticResource PropTextBox}"/>
                        <Label Content="背景色" Style="{StaticResource PropLabel}"/>
                        <TextBox x:Name="PropBackground" Text="#00000000" Style="{StaticResource PropTextBox}"/>
                        <CheckBox x:Name="PropTransparent" Content="透明背景" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="字体" Style="{StaticResource PropLabel}"/>
                        <ComboBox x:Name="PropFontFamily" Height="26" SelectionChanged="PropFontFamily_SelectionChanged">
                            <ComboBoxItem FontFamily="Arial">Arial</ComboBoxItem>
                            <ComboBoxItem FontFamily="Calibri">Calibri</ComboBoxItem>
                            <ComboBoxItem FontFamily="Cambria">Cambria</ComboBoxItem>
                            <ComboBoxItem FontFamily="Consolas" IsSelected="True">Consolas</ComboBoxItem>
                            <ComboBoxItem FontFamily="Courier New">Courier New</ComboBoxItem>
                            <ComboBoxItem FontFamily="Georgia">Georgia</ComboBoxItem>
                            <ComboBoxItem FontFamily="Impact">Impact</ComboBoxItem>
                            <ComboBoxItem FontFamily="Segoe UI">Segoe UI</ComboBoxItem>
                            <ComboBoxItem FontFamily="Tahoma">Tahoma</ComboBoxItem>
                            <ComboBoxItem FontFamily="Times New Roman">Times New Roman</ComboBoxItem>
                            <ComboBoxItem FontFamily="Trebuchet MS">Trebuchet MS</ComboBoxItem>
                            <ComboBoxItem FontFamily="Verdana">Verdana</ComboBoxItem>
                        </ComboBox>
                        <Label Content="字号" Style="{StaticResource PropLabel}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="46"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72" Value="14" ValueChanged="SliderVC"/>
                            <TextBox x:Name="FontSizeBox" Grid.Column="1" Text="14" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>

                        <!-- ===== ProgressBar ===== -->
                        <StackPanel x:Name="PanelProgress" Visibility="Collapsed">
                            <TextBlock Text="进度条" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4"/>
                            <CheckBox x:Name="PropShowValueText" Content="显示数值" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <Label Content="文字颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropProgressTextColor" Text="#FFFFFF" Style="{StaticResource PropTextBox}"/>
                            <Label Content="边框厚度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="BorderThicknessSlider" Minimum="0" Maximum="10" Value="0" ValueChanged="SliderVC"/>
                                <TextBox x:Name="BorderThicknessBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="边框颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropBorderColor" Text="#CCCCCC" Style="{StaticResource PropTextBox}"/>
                            <Label Content="圆角" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="RoundnessSlider" Minimum="0" Maximum="40" Value="0" ValueChanged="SliderVC"/>
                                <TextBox x:Name="RoundnessBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                        </StackPanel>

                        <!-- ===== CircularGauge ===== -->
                        <StackPanel x:Name="PanelGauge" Visibility="Collapsed">
                            <TextBlock Text="环形仪表" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4"/>
                            <Label Content="扇形角度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="SweepAngleSlider" Minimum="60" Maximum="360" Value="270" ValueChanged="SliderVC"/>
                                <TextBox x:Name="SweepAngleBox" Grid.Column="1" Text="270" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="起始角度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="StartAngleSlider" Minimum="-180" Maximum="180" Value="-135" ValueChanged="SliderVC"/>
                                <TextBox x:Name="StartAngleBox" Grid.Column="1" Text="-135" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="环厚度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="RingThicknessSlider" Minimum="2" Maximum="60" Value="14" ValueChanged="SliderVC"/>
                                <TextBox x:Name="RingThicknessBox" Grid.Column="1" Text="14" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <CheckBox x:Name="PropHideTrack" Content="隐藏轨道" IsChecked="False" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <Label Content="轨道颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropTrackColor" Text="#DCDCDC" Style="{StaticResource PropTextBox}"/>
                            <CheckBox x:Name="PropNeedleEnabled" Content="显示指针" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <Label Content="指针颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropNeedleColor" Text="#FF0000" Style="{StaticResource PropTextBox}"/>
                            <Label Content="指针宽度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="NeedleWidthSlider" Minimum="0.5" Maximum="10" Value="2.5" ValueChanged="SliderVC"/>
                                <TextBox x:Name="NeedleWidthBox" Grid.Column="1" Text="2.5" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <CheckBox x:Name="PropShowCenterValue" Content="显示中心数值" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <Label Content="文字颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropGaugeTextColor" Text="#FFFFFF" Style="{StaticResource PropTextBox}"/>
                        </StackPanel>

                        <!-- ===== DigitalDisplay ===== -->
                        <StackPanel x:Name="PanelDisplay" Visibility="Collapsed">
                            <TextBlock Text="数字显示" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4"/>
                            <CheckBox x:Name="PropShowSuffix" Content="显示单位" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <Label Content="小数位数" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="DecimalPlacesSlider" Minimum="0" Maximum="6" Value="1" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                <TextBox x:Name="DecimalPlacesBox" Grid.Column="1" Text="1" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="描边颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropStrokeColor" Text="#CCCCCC" Style="{StaticResource PropTextBox}"/>
                            <Label Content="描边厚度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="StrokeThicknessSlider" Minimum="0" Maximum="8" Value="1" ValueChanged="SliderVC"/>
                                <TextBox x:Name="StrokeThicknessBox" Grid.Column="1" Text="1" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                        </StackPanel>

                        <!-- ===== GridChart ===== -->
                        <StackPanel x:Name="PanelChart" Visibility="Collapsed">
                            <TextBlock Text="折线图" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4"/>
                            <Label Content="时长(秒)" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="DurationSlider" Minimum="10" Maximum="300" Value="60" ValueChanged="SliderVC"/>
                                <TextBox x:Name="DurationBox" Grid.Column="1" Text="60" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="横向网格数" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="GridXSlider" Minimum="1" Maximum="20" Value="5" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                <TextBox x:Name="GridXBox" Grid.Column="1" Text="5" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="纵向网格数" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="GridYSlider" Minimum="1" Maximum="20" Value="4" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                                <TextBox x:Name="GridYBox" Grid.Column="1" Text="4" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="线宽" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="LineWidthSlider" Minimum="0.5" Maximum="8" Value="2" ValueChanged="SliderVC"/>
                                <TextBox x:Name="LineWidthBox" Grid.Column="1" Text="2" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <Label Content="线条颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropLineColor" Text="#0066CC" Style="{StaticResource PropTextBox}"/>
                            <Label Content="网格线颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropGridLineColor" Text="#E0E0E0" Style="{StaticResource PropTextBox}"/>
                            <Label Content="平滑度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="SmoothFactorSlider" Minimum="0" Maximum="1" Value="0.3" ValueChanged="SliderVC"/>
                                <TextBox x:Name="SmoothFactorBox" Grid.Column="1" Text="0.3" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                            <CheckBox x:Name="PropShowFill" Content="显示填充" IsChecked="False" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <Label Content="填充透明度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="FillOpacitySlider" Minimum="0" Maximum="1" Value="0.2" ValueChanged="SliderVC"/>
                                <TextBox x:Name="FillOpacityBox" Grid.Column="1" Text="0.2" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                        </StackPanel>

                        <!-- ===== SensorLabel ===== -->
                        <StackPanel x:Name="PanelLabel" Visibility="Collapsed">
                            <TextBlock Text="传感器标签" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4"/>
                            <CheckBox x:Name="PropLabelShowPrefix" Content="显示前缀" IsChecked="False" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <CheckBox x:Name="PropLabelShowSuffix" Content="显示后缀" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                            <Label Content="层级数量" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="HierarchyLevelsSlider" Minimum="0" Maximum="6" Value="3" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBox x:Name="HierarchyLevelsBox" Grid.Column="1" Text="3" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="描边颜色" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropLabelStrokeColor" Text="#CCCCCC" Style="{StaticResource PropTextBox}"/>
                            <Label Content="描边厚度" Style="{StaticResource PropLabel}"/>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                                <Slider x:Name="LabelStrokeThicknessSlider" Minimum="0" Maximum="8" Value="1" ValueChanged="SliderVC"/>
                                <TextBox x:Name="LabelStrokeThicknessBox" Grid.Column="1" Text="1" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <!-- Background Properties -->
                    <StackPanel x:Name="PanelBackground" Visibility="Collapsed" Margin="0,0,0,10">
                        <TextBlock Text="背景" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Label Content="背景色" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Rectangle x:Name="BgColorSwatch" Grid.Column="0" Width="16" Height="16" Fill="#0A0A0F"
                                       VerticalAlignment="Center" Margin="0,0,6,0" Cursor="Hand" Stroke="LightGray" StrokeThickness="0.5"
                                       MouseLeftButtonDown="BgColorSwatch_Click"/>
                            <TextBox x:Name="PropBgColor" Grid.Column="1" Text="#0A0A0F" Style="{StaticResource PropTextBox}"/>
                        </Grid>
                        <Label Content="图片路径" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox x:Name="PropBgImagePath" Grid.Column="0" Text="" Style="{StaticResource PropTextBox}" TextWrapping="NoWrap"
                                     IsReadOnly="True" Background="#F0F0F0"/>
                            <Button x:Name="BrowseBgImageBtn" Grid.Column="1" Content="..." Width="28" Height="24" FontSize="11"
                                    Click="BrowseBgImageBtn_Click" Margin="2,0,0,0" ToolTip="选择图片"/>
                            <Button x:Name="ClearBgImageBtn" Grid.Column="2" Content="X" Width="22" Height="24" FontSize="10"
                                    Click="ClearBgImageBtn_Click" Margin="2,0,0,0" ToolTip="清除图片"/>
                        </Grid>
                        <Button x:Name="SaveBgToDirBtn" Content="存至软件目录" Height="24" FontSize="11" Margin="0,4,0,0"
                                Click="SaveBgToDirBtn_Click"/>
                        <Label Content="缩放" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="BgScaleSlider" Minimum="0.1" Maximum="6.0" Value="1.0" ValueChanged="BgScaleSlider_ValueChanged"/>
                            <TextBox x:Name="BgScaleBox" Grid.Column="1" Text="1.0" Width="42" Height="22" Margin="4,0,0,0"
                                     VerticalAlignment="Center" FontSize="11" KeyDown="BgScaleBox_KeyDown"/>
                        </Grid>
                        <Grid Margin="0,4,0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="快捷缩放" Foreground="#888" FontSize="10" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="原比例" Width="50" Height="22" FontSize="10" Click="BgScaleReset_Click"/>
                            <Button Grid.Column="2" Content="宽适应" Width="50" Height="22" FontSize="10" Click="BgScaleFitWidth_Click" Margin="4,0,0,0"/>
                            <Button Grid.Column="3" Content="高适应" Width="50" Height="22" FontSize="10" Click="BgScaleFitHeight_Click" Margin="4,0,0,0"/>
                        </Grid>
                        <Label Content="水平" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="BgOffsetXSlider" Minimum="-2000" Maximum="2000" Value="0" ValueChanged="BgOffsetXSlider_ValueChanged"/>
                            <TextBox x:Name="BgOffsetXBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0"
                                     VerticalAlignment="Center" FontSize="11" KeyDown="BgOffsetXBox_KeyDown"/>
                        </Grid>
                        <Button Content="水平居中" Width="60" Height="22" FontSize="10" Click="BgCenterH_Click" Margin="0,2,0,2"/>
                        <Label Content="垂直" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="BgOffsetYSlider" Minimum="-2000" Maximum="2000" Value="0" ValueChanged="BgOffsetYSlider_ValueChanged"/>
                            <TextBox x:Name="BgOffsetYBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0"
                                     VerticalAlignment="Center" FontSize="11" KeyDown="BgOffsetYBox_KeyDown"/>
                        </Grid>
                        <Button Content="垂直居中" Width="60" Height="22" FontSize="10" Click="BgCenterV_Click" Margin="0,2,0,2"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
