<Window x:Class="SensorPanelToo.Views.ComponentEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SensorPanelToo.Controls"
        Title="Component Editor" Height="750" Width="1060"
        Background="#F0F0F0" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Label" x:Key="PropLabel">
            <Setter Property="Foreground" Value="#333"/><Setter Property="FontSize" Value="12"/><Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style TargetType="TextBox" x:Key="PropTextBox">
            <Setter Property="Background" Value="#FAFAFA"/><Setter Property="Foreground" Value="#222"/><Setter Property="BorderBrush" Value="#CCC"/><Setter Property="Height" Value="24"/><Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="CheckBox" x:Key="PropCheck">
            <Setter Property="Foreground" Value="#222"/><Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="10,8">
            <WrapPanel>
                <TextBlock Text="Component:" Foreground="#555" VerticalAlignment="Center" FontSize="13" Margin="0,0,6,0"/>
                <ComboBox x:Name="ComponentTypeCombo" Width="140" Height="26" SelectionChanged="ComponentTypeCombo_SelectionChanged">
                    <ComboBoxItem Tag="CircularGauge" IsSelected="True">Circular Gauge</ComboBoxItem>
                    <ComboBoxItem Tag="ProgressBar">Progress Bar</ComboBoxItem>
                    <ComboBoxItem Tag="DigitalDisplay">Digital Display</ComboBoxItem>
                    <ComboBoxItem Tag="GridChart">Grid Chart</ComboBoxItem>
                </ComboBox>
                <TextBlock Text="Value:" Foreground="#555" VerticalAlignment="Center" FontSize="13" Margin="18,0,6,0"/>
                <Slider x:Name="ValueSlider" Minimum="0" Maximum="100" Value="45" Width="140" VerticalAlignment="Center" ValueChanged="ValueSlider_ValueChanged"/>
                <TextBlock x:Name="ValueLabel" Text="45%" Foreground="#0066CC" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="8,0,0,0" Width="40"/>
                <Rectangle Width="1" Fill="#DDD" Margin="16,2,14,2"/>
                <TextBlock Text="Sensor:" Foreground="#555" VerticalAlignment="Center" FontSize="13" Margin="0,0,4,0"/>
                <Button x:Name="SetupHwBtn" Content="Setup Hardware" Width="110" Height="24" FontSize="11" Click="SetupHwBtn_Click"/>
                <Button x:Name="SelectSensorBtn" Content="Select..." Width="60" Height="24" FontSize="11" Click="SelectSensorBtn_Click"/>
                <TextBlock x:Name="RealSensorLabel" Text="" Foreground="#0066CC" FontSize="12" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                <Button x:Name="ClearBindBtn" Content="X" Width="22" Height="22" Click="ClearBindBtn_Click" FontSize="10" ToolTip="Clear"/>
                <Rectangle Width="1" Fill="#DDD" Margin="16,2,14,2"/>
                <Button x:Name="ApplyBtn" Content="Apply" Width="70" Height="28" FontSize="13" FontWeight="Bold" Click="ApplyBtn_Click" Background="#0066CC" Foreground="White" BorderThickness="0"/>
            </WrapPanel>
        </Border>

        <Border x:Name="TreePopup" Grid.Row="1" Panel.ZIndex="10" VerticalAlignment="Top" HorizontalAlignment="Right" Width="320" Height="400" Margin="0,10,340,0" Background="White" BorderBrush="#CCC" BorderThickness="1" Visibility="Collapsed" CornerRadius="4">
            <Grid Margin="6">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Select Sensor" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="#333"/>
                    <Button Content="X" Width="20" Height="20" FontSize="10" HorizontalAlignment="Right" Margin="180,0,0,0" Click="CloseTreePopup_Click"/>
                </StackPanel>
                <controls:SensorTreeSelector x:Name="SensorTreeSelector" Grid.Row="1" SelectionChanged="SensorTreeSelector_SelectionChanged"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="3"/><ColumnDefinition Width="320"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F8F8F8" Margin="10" Width="600" Height="600" HorizontalAlignment="Center" VerticalAlignment="Center" BorderBrush="#DDD" BorderThickness="1">
                <Canvas x:Name="RenderCanvas" Width="600" Height="600" ClipToBounds="True" Background="White">
                    <controls:ProgressBarControl x:Name="ProgressBarCtrl" Visibility="Collapsed"/>
                    <controls:CircularGaugeControl x:Name="CircularGaugeCtrl"/>
                    <controls:DigitalDisplayControl x:Name="DigitalDisplayCtrl" Visibility="Collapsed"/>
                    <controls:GridChartControl x:Name="GridChartCtrl" Visibility="Collapsed"/>
                </Canvas>
            </Border>

            <GridSplitter Grid.Column="1" Width="3" Background="#DDD" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="0,10,6,10">
                <StackPanel x:Name="PropertyPanel" Margin="4,0,0,0">

                    <TextBlock Text="尺寸" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,8,0,4" ToolTip="Size"/>
                    <Label Content="缩放" ToolTip="Scale" Style="{StaticResource PropLabel}"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                        <Slider x:Name="ScaleSlider" Minimum="0.2" Maximum="3.0" Value="1.0" ValueChanged="SliderVC"/>
                        <TextBox x:Name="ScaleBox" Grid.Column="1" Text="1.0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                    </Grid>

                    <TextBlock Text="外观" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4" ToolTip="Appearance"/>
                    <Label Content="前景色" ToolTip="ForegroundColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropForeground" Text="#FF6644" Style="{StaticResource PropTextBox}"/>
                    <Label Content="背景色" ToolTip="BackgroundColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropBackground" Text="#00000000" Style="{StaticResource PropTextBox}"/>
                    <CheckBox x:Name="PropTransparent" Content="透明背景" ToolTip="TransparentBackground" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                    <Label Content="字体" ToolTip="FontFamily" Style="{StaticResource PropLabel}"/>
                    <ComboBox x:Name="PropFontFamily" Height="26" SelectionChanged="PropFontFamily_SelectionChanged">
                        <ComboBoxItem FontFamily="Arial">Arial</ComboBoxItem>
                        <ComboBoxItem FontFamily="Calibri">Calibri</ComboBoxItem>
                        <ComboBoxItem FontFamily="Cambria">Cambria</ComboBoxItem>
                        <ComboBoxItem FontFamily="Consolas" IsSelected="True">Consolas</ComboBoxItem>
                        <ComboBoxItem FontFamily="Courier New">Courier New</ComboBoxItem>
                        <ComboBoxItem FontFamily="Georgia">Georgia</ComboBoxItem>
                        <ComboBoxItem FontFamily="Impact">Impact</ComboBoxItem>
                        <ComboBoxItem FontFamily="Segoe UI">Segoe UI</ComboBoxItem>
                        <ComboBoxItem FontFamily="Tahoma">Tahoma</ComboBoxItem>
                        <ComboBoxItem FontFamily="Times New Roman">Times New Roman</ComboBoxItem>
                        <ComboBoxItem FontFamily="Trebuchet MS">Trebuchet MS</ComboBoxItem>
                        <ComboBoxItem FontFamily="Verdana">Verdana</ComboBoxItem>
                    </ComboBox>
                    <Label Content="字号" ToolTip="FontSize" Style="{StaticResource PropLabel}"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                        <Slider x:Name="FontSizeSlider" Minimum="8" Maximum="72" Value="14" ValueChanged="SliderVC"/>
                        <TextBox x:Name="FontSizeBox" Grid.Column="1" Text="14" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                    </Grid>

                    <!-- ProgressBar -->
                    <StackPanel x:Name="PanelProgress" Visibility="Collapsed">
                        <TextBlock Text="进度条" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4" ToolTip="ProgressBar"/>
                        <CheckBox x:Name="PropShowValueText" Content="显示数值" ToolTip="ShowValueText" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="文字颜色" ToolTip="TextColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropProgressTextColor" Text="#FFFFFF" Style="{StaticResource PropTextBox}"/>
                        <Label Content="边框厚度" ToolTip="BorderThickness" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="BorderThicknessSlider" Minimum="0" Maximum="10" Value="0" ValueChanged="SliderVC"/>
                            <TextBox x:Name="BorderThicknessBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="边框颜色" ToolTip="BorderColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropBorderColor" Text="#CCCCCC" Style="{StaticResource PropTextBox}"/>
                        <Label Content="圆角" ToolTip="Roundness" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="RoundnessSlider" Minimum="0" Maximum="40" Value="0" ValueChanged="SliderVC"/>
                            <TextBox x:Name="RoundnessBox" Grid.Column="1" Text="0" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                    </StackPanel>

                    <!-- CircularGauge -->
                    <StackPanel x:Name="PanelGauge">
                        <TextBlock Text="环形仪表" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4" ToolTip="CircularGauge"/>
                        <Label Content="扇形角度" ToolTip="SweepAngle" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="SweepAngleSlider" Minimum="60" Maximum="360" Value="270" ValueChanged="SliderVC"/>
                            <TextBox x:Name="SweepAngleBox" Grid.Column="1" Text="270" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="起始角度" ToolTip="StartAngle" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="StartAngleSlider" Minimum="-180" Maximum="180" Value="-135" ValueChanged="SliderVC"/>
                            <TextBox x:Name="StartAngleBox" Grid.Column="1" Text="-135" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="环厚度" ToolTip="RingThickness" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="RingThicknessSlider" Minimum="2" Maximum="60" Value="14" ValueChanged="SliderVC"/>
                            <TextBox x:Name="RingThicknessBox" Grid.Column="1" Text="14" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <CheckBox x:Name="PropNeedleEnabled" Content="显示指针" ToolTip="NeedleEnabled" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="指针颜色" ToolTip="NeedleColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropNeedleColor" Text="#FF0000" Style="{StaticResource PropTextBox}"/>
                        <Label Content="指针宽度" ToolTip="NeedleWidth" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="NeedleWidthSlider" Minimum="0.5" Maximum="10" Value="2.5" ValueChanged="SliderVC"/>
                            <TextBox x:Name="NeedleWidthBox" Grid.Column="1" Text="2.5" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <CheckBox x:Name="PropShowCenterValue" Content="显示中心数值" ToolTip="ShowCenterValue" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="文字颜色" ToolTip="TextColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropGaugeTextColor" Text="#FFFFFF" Style="{StaticResource PropTextBox}"/>
                    </StackPanel>

                    <!-- DigitalDisplay -->
                    <StackPanel x:Name="PanelDisplay" Visibility="Collapsed">
                        <TextBlock Text="数字显示" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4" ToolTip="DigitalDisplay"/>
                        <CheckBox x:Name="PropShowSuffix" Content="显示单位" ToolTip="ShowSuffix" IsChecked="True" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="小数位数" ToolTip="DecimalPlaces" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="DecimalPlacesSlider" Minimum="0" Maximum="6" Value="1" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBox x:Name="DecimalPlacesBox" Grid.Column="1" Text="1" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="描边颜色" ToolTip="StrokeColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropStrokeColor" Text="#CCCCCC" Style="{StaticResource PropTextBox}"/>
                        <Label Content="描边厚度" ToolTip="StrokeThickness" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="StrokeThicknessSlider" Minimum="0" Maximum="8" Value="1" ValueChanged="SliderVC"/>
                            <TextBox x:Name="StrokeThicknessBox" Grid.Column="1" Text="1" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                    </StackPanel>

                    <!-- GridChart -->
                    <StackPanel x:Name="PanelChart" Visibility="Collapsed">
                        <TextBlock Text="折线图" Foreground="#999" FontSize="11" FontWeight="Bold" Margin="0,14,0,4" ToolTip="GridChart"/>
                        <Label Content="时长(秒)" ToolTip="DurationSeconds" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="DurationSlider" Minimum="10" Maximum="300" Value="60" ValueChanged="SliderVC"/>
                            <TextBox x:Name="DurationBox" Grid.Column="1" Text="60" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="横向网格数" ToolTip="GridDensityX" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="GridXSlider" Minimum="1" Maximum="20" Value="5" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBox x:Name="GridXBox" Grid.Column="1" Text="5" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="纵向网格数" ToolTip="GridDensityY" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="GridYSlider" Minimum="1" Maximum="20" Value="4" ValueChanged="SliderVC" IsSnapToTickEnabled="True" TickFrequency="1"/>
                            <TextBox x:Name="GridYBox" Grid.Column="1" Text="4" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="线宽" ToolTip="LineWidth" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="LineWidthSlider" Minimum="0.5" Maximum="8" Value="2" ValueChanged="SliderVC"/>
                            <TextBox x:Name="LineWidthBox" Grid.Column="1" Text="2" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <Label Content="线条颜色" ToolTip="LineColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropLineColor" Text="#0066CC" Style="{StaticResource PropTextBox}"/>
                        <Label Content="网格线颜色" ToolTip="GridLineColor" Style="{StaticResource PropLabel}"/><TextBox x:Name="PropGridLineColor" Text="#E0E0E0" Style="{StaticResource PropTextBox}"/>
                        <Label Content="平滑度" ToolTip="SmoothFactor" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="SmoothFactorSlider" Minimum="0" Maximum="1" Value="0.3" ValueChanged="SliderVC"/>
                            <TextBox x:Name="SmoothFactorBox" Grid.Column="1" Text="0.3" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                        <CheckBox x:Name="PropShowFill" Content="显示填充" ToolTip="ShowFill" IsChecked="False" Style="{StaticResource PropCheck}" Margin="0,6,0,2" Checked="CheckBox_Changed" Unchecked="CheckBox_Changed"/>
                        <Label Content="填充透明度" ToolTip="FillOpacity" Style="{StaticResource PropLabel}"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="46"/></Grid.ColumnDefinitions>
                            <Slider x:Name="FillOpacitySlider" Minimum="0" Maximum="1" Value="0.2" ValueChanged="SliderVC"/>
                            <TextBox x:Name="FillOpacityBox" Grid.Column="1" Text="0.2" Width="42" Height="22" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="11" KeyDown="BoxKD"/>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
