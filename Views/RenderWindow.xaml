<Window x:Class="SensorPanelToo.Views.RenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SensorPanel 渲染"
        WindowStyle="None" AllowsTransparency="False"
        ResizeMode="NoResize" Topmost="True"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded" Background="#000000">
    <Viewbox x:Name="Viewbox" Stretch="Uniform">
        <Border x:Name="ViewboxBorder">
            <Canvas x:Name="RenderCanvas" Background="#0A0A0F" ClipToBounds="True">
                <Image x:Name="BgImage" Stretch="None" HorizontalAlignment="Left" VerticalAlignment="Top"
                       Panel.ZIndex="-100" IsHitTestVisible="False"/>
            </Canvas>
        </Border>
    </Viewbox>
</Window>
